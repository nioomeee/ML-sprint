   "source": [
    "import pandas as pd\n",
    "\n",
    "data = {\n",
    "    'Raw_Date': ['2023-01-01', '01/02/2023', '2023.03.03']\n",
    "}\n",
    "\n",
    "df = pd.DataFrame(data)\n",
    "print(\"Before: \")\n",
    "print(df)\n",
    "\n",
    "df['Clean_Date'] = pd.to_datetime(df['Raw_Date'], format='mixed')\n",
    "\n",
    "print(\"\\nAfter:\")\n",
    "print(df)"
   ]
  }
