   "source": [
    "import pandas as pd\n",
    "\n",
    "data = {\n",
    "    'Employee': ['John', 'Anna', 'Peter'],\n",
    "    'Department': ['HR', 'IT', 'Finance']\n",
    "}\n",
    "\n",
    "df = pd.DataFrame(data)\n",
    "\n",
    "df_encoded = pd.get_dummies(df, columns=['Department'])\n",
    "\n",
    "print(\"After One-Hot Encoding: \")\n",
    "print(df_encoded)"
   ]
  }
 ],
